_schema-version: "3.2"
ID: sapuidemocart-qa

extends: sapuidemocart

resources:

  - name: sapuidemocart-destination-service
    parameters:
      service-name: sapuidemocart-destination-service-qa

  - name: sapuidemocart-uaa
    parameters:
      service-name: sapuidemocart-xsuaa-service-qa
      config:
        xsappname: sapuidemocart-qa

  - name: sapuidemocart-repo-host
    parameters:
      service-name: sapuidemocart-html5-service-qa

modules:
  - name: sapuidemocart-destination-content
    parameters:
      content:
        instance:
          destinations:
            - Name: sapuidemocart_html_repo_host
              ServiceInstanceName: sapuidemocart-html5-service-qa
              ServiceKeyName: sapuidemocart-repo-host-key
              sap.cloud.service: sapuidemocart

            - Authentication: OAuth2UserTokenExchange
              Name: sapuidemocart_uaa
              ServiceInstanceName: sapuidemocart-xsuaa-service-qa
              ServiceKeyName: sapuidemocart-uaa-key
              sap.cloud.service: sapuidemocart